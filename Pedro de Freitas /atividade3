def next_permutation(w):
    a = list(w)
    n = len(a)

    i = n - 2
    while i >= 0 and a[i] >= a[i + 1]:
        i -= 1

    if i < 0:
        return "no answer"

    j = n - 1
    while a[j] <= a[i]:
        j -= 1

    a[i], a[j] = a[j], a[i]
    a[i + 1:] = a[i + 1:][::-1]

    return ''.join(a)


T = int(input())

for _ in range(T):
    print(next_permutation(input().strip()))
