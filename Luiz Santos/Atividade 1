a =  int(input("Digite o 1º número: "))                           # Recebe o valor de a

while a < 1:                                                      # Testa adequação à restrição 1 <= a
  print("**ERRO: O 1º número precisa ser maior ou igual a 1")
  a = int(input("Digite outro número: "))

